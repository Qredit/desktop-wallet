{
  "name": "ArkClient",
  "version": "3.0.0",
  "description": "Qredit Desktop Wallet",
  "keywords": [
    "Qredit",
    "Client",
    "Electron"
  ],
  "homepage": "https://github.com/qredit/desktop-wallet#readme",
  "bugs": {
    "url": "https://github.com/qredit/desktop-wallet/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qredit/desktop-wallet.git"
  },
  "license": "MIT",
  "author": {
    "name": "Fx Thoorens",
    "email": "fixcrypt@gmail.com",
    "url": "https://github.com/fix"
  },
  "contributors": [
    {
      "name": "Guillaume Verbal",
      "email": "doweig@ark.io",
      "url": "https://github.com/doweig"
    },
    {
      "name": "Lucio Rubens",
      "email": "lucio@ark.io",
      "url": "https://github.com/luciorubeens"
    },
    {
      "name": "Juan A. Martín",
      "email": "juan@ark.io",
      "url": "https://github.com/j-a-m-l"
    }
  ],
  "main": "main.js",
  "scripts": {
    "bundle": "browserify -r angular -r bip39 -r angular-animate -r angular-aria -r angular-gettext -r angular-material -r ng-infinite-scroll -r angular-material-data-table -r angular-messages -r rss-parser -r qrcode-generator -r angular-qrcode -r @uirouter/angularjs -r qreditjs -r jsqr -r node-vibrant app/index.js | minify > app/dependencies.min.js",
    "dist": "npm run dist:win && npm run dist:macos && npm run dist:linux && npm run dist:win32",
    "dist-quick": "npm run dist:win && npm run dist:macos && npm run dist:linux",
    "dist:linux": "electron-builder --linux",
    "dist:macos": "electron-builder --macos",
    "dist:win": "electron-builder --win",
    "dist:win32": "electron-builder --win --ia32",
    "electron": "electron --version",
    "eslint": "eslint \"**/*.js\"",
    "postinstall": "npm run bundle && electron-builder install-app-deps && npm run rebuild",
    "live-reload": "cross-env LIVE_RELOAD=true electron main.js -- --disableScreenshotProtection",
    "pack": "build --dir",
    "rebuild": "electron-rebuild --force --module_dir . -w node-hid ",
    "prestart": "npm update",
    "start": "electron main.js -- --disableScreenshotProtection",
    "test": "karma start test/karma.conf.js --single-run",
    "test-app": "mocha --recursive ./test/e2e/scenarios",
    "test-watch": "karma start test/karma.conf.js"
  },
  "dependencies": {
    "@destinationstransfers/ntp": "^1.1.0",
    "@ledgerhq/hw-transport-node-hid-singleton": "^5.0.0",
    "@qredit/crypto": "^2.6.27",
    "@uirouter/angularjs": "^1.0.11",
    "@vaporyjs/ledgerco": "^1.1.3",
    "about-window": "^1.11.0",
    "angular": "^1.6.1",
    "angular-animate": "^1.6.1",
    "angular-aria": "^1.6.1",
    "angular-gettext": "^2.3.6",
    "angular-material": "^1.1.5",
    "angular-material-data-table": "git://github.com/daniel-nagy/md-data-table.git#master",
    "angular-messages": "^1.5.5",
    "angular-qrcode": "^7.2.0",
    "ark-qrcode": "git://github.com/qredit/ark-qrcode.git#master",
    "async": "^2.5.0",
    "axios": "^0.19.0",
    "big.js": "^5.2.2",
    "bip39": "^2.2.0",
    "csv-parse": "^2.0.0",
    "electron-window-state": "^4.1.1",
    "elemon": "^5.0.3",
    "jsqr": "^0.2.2",
    "moment": "^2.24.0",
    "moment-range": "^3.1.0",
    "moment-timezone": "^0.5.14",
    "ng-infinite-scroll": "^1.3.0",
    "node-emoji": "^1.10.0",
    "node-gyp": "^8.1.0",
    "node-vibrant": "^3.0.0-alpha.2",
    "q": "1.5.1",
    "qrcode-generator": "^1.3.1",
    "qreditjs": "git://github.com/qredit/qredit-js.git#master",
    "request": "^2.88.0",
    "rss-parser": "^2.10.8"
  },
  "devDependencies": {
    "angular-mocks": "^1.6.6",
    "babel-core": "^6.26.0",
    "babel-minify": "^0.4.3",
    "babel-preset-es2015": "^6.24.1",
    "browserify": "^14.5.0",
    "chai": "^4.1.2",
    "chai-as-promised": "^7.1.1",
    "cross-env": "^5.0.5",
    "devtron": "^1.4.0",
    "electron": "^8.3.0",
    "electron-builder": "^20.15.0",
    "electron-rebuild": "^2.3.5",
    "eslint": "^4.14.0",
    "eslint-config-standard": "^11.0.0-beta.0",
    "eslint-plugin-import": "^2.8.0",
    "eslint-plugin-node": "^5.2.1",
    "eslint-plugin-promise": "^3.6.0",
    "eslint-plugin-standard": "^3.0.1",
    "grunt": "~1.0.1",
    "grunt-angular-gettext": "^2.3.6",
    "grunt-contrib-jshint": "~1.1.0",
    "grunt-contrib-nodeunit": "^2.0.0",
    "grunt-contrib-uglify": "~3.1.0",
    "karma": "^2.0.2",
    "karma-babel-preprocessor": "^7.0.0",
    "karma-coverage": "^1.1.1",
    "karma-electron": "^5.2.1",
    "karma-mocha": "^1.3.0",
    "karma-sinon": "^1.0.5",
    "karma-sinon-chai": "^1.3.3",
    "mocha": "^5.2.0",
    "sinon": "^4.1.1",
    "sinon-chai": "^2.14.0",
    "spectron": "^3.7.2"
  },
  "build": {
    "appId": "io.qredit.wallet",
    "protocols": {
      "name": "Qredit URI scheme",
      "schemes": [
        "xqr"
      ],
      "role": "Viewer"
    },
    "mac": {
      "category": "finance"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "description": "A Lite Client used to securely connect to the Qredit network and manage your Qredit assets.",
      "target": [
        "deb",
        "tar.xz"
      ],
      "desktop": {
        "MimeType": "x-scheme-handler/qredit;"
      },
      "category": "Network"
    },
    "deb": {
      "synopsis": "Qredit Desktop Wallet"
    },
    "dmg": {
      "icon": "build/icon.icns"
    },
    "nsis": {
      "perMachine": true,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "productName": "QreditClient"
}